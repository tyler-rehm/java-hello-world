###############################################################################
# Gradle
###############################################################################
.gradle/
build/
.kotlin

# Allow Gradle wrapper JAR (required for builds)
!gradle/wrapper/gradle-wrapper.jar

# Allow build dirs under source sets (as originally specified)
!**/src/main/**/build/
!**/src/test/**/build/

###############################################################################
# IntelliJ IDEA
###############################################################################
.idea/
.idea/modules.xml
.idea/jarRepositories.xml
.idea/compiler.xml
.idea/libraries/
*.iws
*.iml
*.ipr
out/

# Allow out dirs under source sets (as originally specified)
!**/src/main/**/out/
!**/src/test/**/out/

###############################################################################
# Eclipse
###############################################################################
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/

# Allow bin dirs under source sets (as originally specified)
!**/src/main/**/bin/
!**/src/test/**/bin/

###############################################################################
# NetBeans
###############################################################################
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

